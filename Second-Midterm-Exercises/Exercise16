#include "iostream"
#include "string.h"
using namespace std;
class Transport {
protected:
    char destinacija[50];
    int cena;
    int km;
public:
    Transport(const char *destinacija="", int cena=0, int km=0){
        strcpy(this->destinacija,destinacija);
        this->cena=cena;
        this->km=km;
    }
    virtual int cenaTransport()=0;
    bool operator<(Transport &a){
        return this->km<a.km;
    }
    int getKM()const{
        return km;
    };
    char *getDest(){
        return destinacija;
    }
};
class AvtomobilTransport:public Transport{
private:
    bool shofer;
public:
    AvtomobilTransport(const char *destinacija="", int cena=0, int km=0, bool shofer=false)
    : Transport(destinacija,cena,km){
        this->shofer=shofer;
    }
    int cenaTransport(){
        if(shofer){
            return cena+(cena*0.2);
        }
        return cena;
    }
    bool operator<(AvtomobilTransport &a){
        return this->km<a.km;
    }
};
class KombeTransport:public Transport{
private:
    int brojLugje;
public:
    KombeTransport(const char *destinacija="", int cena=0, int km=0, int brojlugje=0)
            : Transport(destinacija,cena,km){
        this->brojLugje=brojlugje;
    }
    int cenaTransport(){
            return cena-(brojLugje*200);
    }
    bool operator<(KombeTransport &a){
        return this->km<a.km;
    }
};
void pecatiPoloshiPonudi(Transport**t, int n, Transport &trans){
    for (int i = 0; i < n; ++i) {
        for (int j = 0; j < n; ++j) {
            if(t[i]->getKM()<t[j]->getKM()){
                Transport *tmp=t[i];
                t[i]=t[j];
                t[j]=tmp;
            }
        }
    }
    for (int i = 0; i < n; ++i) {
        if(t[i]->cenaTransport()>trans.cenaTransport()){
            cout<<t[i]->getDest()<<" "<<t[i]->getKM()<<" "<<t[i]->cenaTransport()<<endl;
        }
    }
}
int main(){

    char destinacija[20];
    int tip,cena,rastojanie,lugje;
    bool shofer;
    int n;
    cin>>n;
    Transport  **ponudi;
    ponudi=new Transport *[n];

    for (int i=0;i<n;i++){

        cin>>tip>>destinacija>>cena>>rastojanie;
        if (tip==1) {
            cin>>shofer;
            ponudi[i]=new AvtomobilTransport(destinacija,cena,rastojanie,shofer);

        }
        else {
            cin>>lugje;
            ponudi[i]=new KombeTransport(destinacija,cena,rastojanie,lugje);
        }


    }

    AvtomobilTransport nov("Ohrid",2000,600,false);
    pecatiPoloshiPonudi(ponudi,n,nov);

    for (int i=0;i<n;i++) delete ponudi[i];
    delete [] ponudi;
    return 0;
}
