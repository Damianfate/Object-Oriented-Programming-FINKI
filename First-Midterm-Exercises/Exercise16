#include <stdio.h>
#include <string.h>
#define NEDELI 4
#define DENOVI 5

typedef struct {
    int casovi[DENOVI];
    int brojNedela;
} RabotnaNedela;

typedef struct {
    char ime[50];
    RabotnaNedela nedeli[NEDELI];
} Rabotnik;

int maxNedela(Rabotnik *r) {
    int maxCasovi = 0, maxIndex = 0;
    for (int i = 0; i < NEDELI; i++) {
        int suma = 0;
        for (int j = 0; j < DENOVI; j++) {
            suma += r->nedeli[i].casovi[j];
        }
        if (suma > maxCasovi) {
            maxCasovi = suma;
            maxIndex = r->nedeli[i].brojNedela;
        }
    }
    return maxIndex;
}

void table(Rabotnik *r, int n) {
    printf("Rab\t1\t2\t3\t4\tVkupno\n");
    for (int i = 0; i < n; i++) {
        printf("%s\t", r[i].ime);
        int vkupnoCasovi = 0;
        for (int j = 0; j < NEDELI; j++) {
            int suma = 0;
            for (int k = 0; k < DENOVI; k++) {
                suma += r[i].nedeli[j].casovi[k];
            }
            vkupnoCasovi += suma;
            printf("%d\t", suma);
        }
        printf("%d\n", vkupnoCasovi);
    }
}

int main() {
    int n;
    scanf("%d", &n);
    Rabotnik rabotnici[n];
    
    for (int i = 0; i < n; ++i) {
        scanf("%s", rabotnici[i].ime);
        for (int j = 0; j < NEDELI; ++j) {
            rabotnici[i].nedeli[j].brojNedela = j + 1;
            for (int k = 0; k < DENOVI; ++k) {
                scanf("%d", &rabotnici[i].nedeli[j].casovi[k]);
            }
        }
    }
    
    printf("TABLE\n");
    table(rabotnici, n);
    printf("MAX NEDELA NA RABOTNIK: %s\n", rabotnici[n / 2].ime);
    printf("%d\n", maxNedela(&rabotnici[n / 2]));
    
    return 0;
}
