#include<iostream>
#include<cstring>
using namespace std;
enum Extension {
    pdf, txt, exe
};

class File {
private:
    char *fileName;
    Extension ext;
    char *fileOwner;
    int fileSize;

    const char *getDatoteka() const {
        switch (ext) {
            case Extension::txt:
                return "txt";
            case Extension::pdf:
                return "pdf";
            case Extension::exe:
                return "exe";
        }
        return "glup";
    }

public:
    File() {
        fileName = nullptr;
        fileOwner = nullptr;
        fileSize = 0;
    }

    File(const char *fileName,const char *fileOwner, int fileSize, Extension d) {
        this->fileName = new char[strlen(fileName) + 1];
        strcpy(this->fileName, fileName);
        this->fileOwner = new char[strlen(fileOwner) + 1];
        strcpy(this->fileOwner, fileOwner);
        this->ext = d;
        this->fileSize = fileSize;
    }
    File(const File &f) {
        this->fileName = new char[strlen(f.fileName) + 1];
        strcpy(this->fileName, f.fileName);
        this->fileOwner = new char[strlen(f.fileOwner) + 1];
        strcpy(this->fileOwner, f.fileOwner);
        this->ext = f.ext;
        this->fileSize = f.fileSize;
    }

    ~File() {
        delete[] fileName;
        delete[] fileOwner;
    }

    File &operator=(const File &f) {
        if (this != &f) {
            this->fileName = new char[strlen(f.fileName) + 1];
            strcpy(fileName, f.fileName);
            this->fileOwner = new char[strlen(f.fileOwner) + 1];
            strcpy(this->fileOwner, f.fileOwner);
            this->ext = f.ext;
            this->fileSize = f.fileSize;
        }
        return *this;
    }

    void print() {
        cout << "File name: " << fileName << "." << getDatoteka() << endl;
        cout << "File owner: " << fileOwner << endl;
        cout << "File size: " << fileSize << endl;
    }

    bool equals(const File &that) {
        return (this->equalsType(that) && strcmp(this->fileOwner, that.fileOwner) == 0);
    }

    bool equalsType(const File &that) {
        return (strcmp(this->fileName, that.fileName) == 0 && this->ext == that.ext);
    }
};

class Folder {
    char *diretkorium;
    int brojdatoteki;
    File *files;
public:
    Folder(const char *name) {
        brojdatoteki = 0;
        files = nullptr;
        this->diretkorium = new char[strlen(name) + 1];
        strcpy(this->diretkorium, name);
    }

    ~Folder() {
        delete[] diretkorium;
        delete[] files;
    }

    void print() {
        cout <<"Folder name: " <<diretkorium << endl;
        for (int i = 0; i < brojdatoteki; ++i) {
            files[i].print();
        }
    }

    void remove(const File &file) {
        File *tmp = new File[brojdatoteki - 1];
        int novi = 0;
        bool d = false;
        for (int i = 0; i < brojdatoteki; ++i) {
            if (files[i].equals(file) && !d){
                d = true;
            }else tmp[novi++] = files[i];
        }
        brojdatoteki--;
        delete [] files;
        files=tmp;
    }
    void add(const File & file){
        File *tmp = new File[brojdatoteki + 1];
        for (int i = 0; i < brojdatoteki; ++i) {
            tmp[i]=files[i];
        }
        tmp[brojdatoteki++] = file;
        delete [] files;
        files=tmp;
    }
};

