using namespace std;

void wtf() {
    ofstream fout("vlezna.txt");
    string line;
    while (getline(std::cin, line)) {
        if (line == "----") {
            break;
        }
        fout << line << endl;
    }
}

void rff(string path) {
    ifstream fin(path);
    string line;
    while (getline(fin, line)) {
        cout << line << endl;
    }
}

class Song {
private:
    string naslov;
    string avtor;
    string izveduvac;
    int traenje;
public:
    Song(string naslov = "", string avtor = "", string izveduvac = "", int traenje = 0) {
        this->naslov = naslov;
        this->avtor = avtor;
        this->izveduvac = izveduvac;
        this->traenje = traenje;
    }

    void SetNaslov(string n) {
        this->naslov = n;
    }

    void SetAvtor(string a) {
        this->avtor = a;
    }

    void SetIzveduvac(string i) {
        this->izveduvac = i;
    }

    void SetTraenje(int t) {
        this->traenje = t;
    }

    string GetNaslov() {
        return naslov;
    }

    string GetAvtor() {
        return avtor;
    }

    string getIzveduvac() {
        return izveduvac;
    }

    int getTraenje() {
        return traenje;
    }

    friend istream &operator>>(istream &i, Song &s) {
        getline(i,s.naslov);
        getline(i,s.avtor);
        getline(i,s.izveduvac);
        i>>s.traenje;
        i.ignore();
        return i;
    }

    void print(ofstream &out) {
        out << "Song title: " << naslov << ", Author: " << avtor << ", Interpreted by: " << izveduvac << ", " << traenje
            << " sek.";
    }
    bool Isti(const Song&s){
        return naslov==s.naslov&&avtor==s.avtor&&izveduvac==s.izveduvac&&traenje==s.traenje;
    }
};

