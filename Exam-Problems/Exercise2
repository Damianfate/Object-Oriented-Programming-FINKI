#include <iostream>
#include <cstring>
#include <stdexcept>

using namespace std;

class InvalidCodeFormatException : public exception {
public:
    string kod;

    InvalidCodeFormatException(string k) : kod(k) {
    }
    void print(){
        cout << "The code " << kod
             << " is invalid doctor code format. THE CODE MUST BE 8 CHARACTERS LONG AND CANNOT CONTAIN COMMA." << endl;
    }
};

class Doctor {
protected:
    string ime;
    string prezime;
    double plata;
    string kod;
public:
    Doctor(string ime = "", string prezime = "", double plata = 0, string kod = "") {
        if (kod.length() != 8 || kod.find(",")!=string::npos) {
            throw InvalidCodeFormatException(kod);
        } else {
            this->ime = ime;
            this->plata = plata;
            this->prezime = prezime;
            this->kod = kod;
        }
    }

    virtual float calculateSalary()const = 0;

    virtual void print() = 0;
};

class GeneralDoctor : public Doctor {
private:
    int pacient;
public:
    GeneralDoctor(string ime = "", string prezime = "",  string kod = "", int pacient = 0) : Doctor(
            ime, prezime, 45000, kod) {
        this->pacient = pacient;
    }
    float calculateSalary()const{
        int dodatok=(pacient/10)*3000;
        return (plata+dodatok)*0.93;
    }
        void print() {
        cout << "General Doctor: " << ime << " " << prezime << " CODE:" << kod << " Salary: " << calculateSalary()
             << endl;
    }
};

class Specialist : public Doctor {
private:
    string spec;
    int intervencii;
    int iskustvo;
public:
    Specialist(string ime = "", string prezime = "", string kod = "", string spec = "",int intervencii=0,
               int iskustvo = 0)
            : Doctor(ime, prezime, 55000, kod) {
        this->spec = spec;
        this->intervencii=intervencii;
        this->iskustvo = iskustvo;
    }

    float calculateSalary() const{
        return (plata + (intervencii * 85) + (plata * iskustvo * 0.05)) * 0.93;
    }
        void print() {
        cout << "Specialist: " << ime << " " << prezime << " CODE:" << kod<<" "<<spec<< " Salary: " << calculateSalary()
             << endl;
    }
};
void findDoctorsPercentage(Doctor **doctors, int n){
    float spec=0,gen=0,valid=0;
    for (int i = 0; i < n; ++i) {
        if(doctors[i]!= nullptr){
            valid++;
            if(dynamic_cast<GeneralDoctor*>(doctors[i])){
                gen+=1;
            } else if(dynamic_cast<Specialist*>(doctors[i])){
                spec+=1;
            }
        }

    }
    cout << spec * 100.00 / valid << "% of the doctors are specialists and " <<gen * 100.00 / valid<< "% are general doctors." << endl;
}

