class Product {
protected:
    string ime;
    string kategorija;
    int cena;
    int kolicina;
public:
    Product(string ime = "", string kategorija = "", int cena = 0, int kolicina = 0) {
        this->ime = ime;
        this->kategorija = kategorija;
        this->cena = cena;
        this->kolicina = kolicina;
    }

    int totalPrice() const {
        return cena * kolicina;
    }
    string getKategorija(){
        return kategorija;
    }
    friend ostream &operator<<(ostream &o,const Product &p) {
        o << p.ime << " (" << p.kategorija << ") " << p.kolicina << " x " << p.cena << " = " << p.totalPrice() << endl;
        return o;
    }
};
class NoProductFoundException{
public:
    string s;
    NoProductFoundException(string s):s(s){}
};

class Store {
protected:
    Product *niza;
    int golemina;
public:
    Store(const Product *niza = nullptr, int golemina = 0) {
        this->golemina = golemina;
        this->niza = new Product[golemina];
        for (int i = 0; i < golemina; ++i) {
            this->niza[i] = niza[i];
        }
    }

    Store(const Store &s) {
        this->golemina = s.golemina;
        this->niza = new Product[s.golemina];
        for (int i = 0; i < s.golemina; ++i) {
            this->niza[i] = s.niza[i];
        }
    }

    Store &operator=(const Store &s) {
        if (this != &s) {
            this->golemina = s.golemina;
            this->niza = new Product[s.golemina];
            for (int i = 0; i < s.golemina; ++i) {
                this->niza[i] = s.niza[i];
            }
        }
        return *this;
    }

    ~Store() {
        delete[]niza;
    }

    Store &operator+=(const Product &p) {
        Product *tmp = new Product[golemina + 1];
        for (int i = 0; i < golemina; ++i) {
            tmp[i] = niza[i];
        }
        tmp[golemina] = p;
        delete[]niza;
        niza = tmp;
        golemina++;
        return *this;
    }

    friend ostream &operator<<(ostream &o, const Store &s) {
        for (int i = 0; i < s.golemina; ++i) {
            o << s.niza[i];
        }
        return o;
    }
    Store fromCategory(string &category){
        Store nova;
        for (int i = 0; i < golemina; ++i) {
            if(niza[i].getKategorija()==category){
                nova+=niza[i];
            }
        }
        if(nova.golemina==0){
            throw NoProductFoundException(category);
        }
        return nova;
    }
};


