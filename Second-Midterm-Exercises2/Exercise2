void rff(string path) {
    ifstream fin(path);
    string line;
    while (getline(fin, line)) {
        cout << line << endl;
    }
}


class Student {
protected:
    string index;
    string ime;
    string prezime;
    int poeni;
public:
    Student(string index = "", string ime = "", string prezime = "", int poeni = 0) {
        this->index = index;
        this->ime = ime;
        this->prezime = prezime;
        this->poeni = poeni;
    }

    friend ostream &operator<<(ostream &o, Student &s) {
        o << s.index << " " << s.ime << " " << s.prezime << " " << s.poeni << " Grade: " << s.grade()<<endl;
        return o;
    }

    string getIndex() const {
        return index;
    }

    int grade() const {
        int ocena = 0;
        if (poeni < 50) {
            ocena = 5;
        } else if (poeni >= 50 && poeni < 60) {
            ocena = 6;
        } else if (poeni >= 60 && poeni < 70) {
            ocena = 7;
        } else if (poeni >= 70 && poeni < 80) {
            ocena = 8;
        } else if (poeni >= 80 && poeni < 90) {
            ocena = 9;
        } else ocena = 10;
        return ocena;
    }
};

class StudentFailedException {
public:
    string index;

    StudentFailedException(string i = "") : index(i) {}
};

class Results {
protected:
    Student *students;
    int broj;
public:
    Results(Student *students = nullptr, int broj = 0) {
        this->broj = broj;
        this->students = new Student[broj];
        for (int i = 0; i < broj; ++i) {
            this->students[i] = students[i];
        }
    }

    Results(const Results &r) {
        this->broj = r.broj;
        this->students = new Student[r.broj];
        for (int i = 0; i < r.broj; ++i) {
            this->students[i] = r.students[i];
        }
    }

    Results &operator=(const Results &r) {
        if (this != &r) {
            this->broj = r.broj;
            this->students = new Student[r.broj];
            for (int i = 0; i < r.broj; ++i) {
                this->students[i] = r.students[i];
            }
        }
        return *this;
    }

    ~Results() {
        delete[] students;
    }

    Results &operator+=(const Student &s) {
        if (s.grade() == 5) {
            throw StudentFailedException(s.getIndex());
        } else {
            Student *tmp = new Student[broj + 1];
            for (int i = 0; i < broj; ++i) {
                tmp[i] = students[i];
            }
            tmp[broj] = s;
            delete[]students;
            students = tmp;
            broj++;
        }
    }

    friend ostream &operator<<(ostream &s, const Results &r) {
        for (int i = 0; i < r.broj; ++i) {
            s << r.students[i];
        }
        return s;
    }

    Results withGrade(int grade) {
        int golemina=0;
        Student *tmp = new Student[broj];
        for (int i = 0; i < broj; ++i) {
            if (students[i].grade() == grade) {
                tmp[golemina++] = students[i];
            }
        }
        Results r(tmp, golemina);
        return r;
    }
    int getBroj()const{
        return broj;
    }
};


